{
  "name": "@agentshield/plugin",
  "version": "0.1.0",
  "description": "AI Agent Security & Guardrails for Solana — Memory injection protection, transaction policies, anomaly detection, and audit logging",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "elizaos",
    "solana",
    "ai-agent",
    "security",
    "guardrails",
    "memory-injection",
    "agentshield",
    "web3",
    "policy-engine"
  ],
  "author": "AgentShield Team",
  "license": "MIT",
  "peerDependencies": {
    "@elizaos/core": ">=2.0.0-alpha.1"
  },
  "devDependencies": {
    "@elizaos/core": "2.0.0-alpha.98",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "vitest": "^4.1.1"
  }
}
